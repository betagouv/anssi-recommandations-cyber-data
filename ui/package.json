{
  "name": "mesquestionscyber",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json --threshold error && tsc -p tsconfig.node.json",
    "lint:check": "eslint .",
    "lint:fix": "eslint --fix .",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "preinstall": "npx only-allow@1.2.2 pnpm",
    "test": "pnpm run svelte:check && vitest run",
    "svelte:check": "svelte-check --tsconfig ./tsconfig.app.json"
  },
  "lint-staged": {
    "*.{ts,js,json,css,md,svelte}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.svelte": [
      "svelte-check --tsconfig ./tsconfig.app.json --threshold error"
    ]
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^22.19.15",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "lint-staged": "^16.3.3",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "sass-embedded": "^1.97.3",
    "svelte": "^5.53.9",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@lab-anssi/ui-kit": "^1.44.2"
  },
  "pnpm": {
    "overrides": {
      "flatted": "^3.4.2"
    }
  }
}
